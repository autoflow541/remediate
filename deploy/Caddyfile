# Caddy reverse proxy for pdf.auto-flow.co — matches /etc/caddy/Caddyfile on the VM.
#
# Routing rule: all non-GET requests go to the FastAPI engine (the SPA only
# serves GETs), so NEW POST ENDPOINTS NEVER NEED A CADDYFILE EDIT. Only the
# GET-able API paths are listed explicitly.
#
# Reload after edits: sudo systemctl reload caddy

pdf.auto-flow.co {
    # GET API routes -> FastAPI engine
    @apiGet path /health /health/* /docs /docs/* /redoc /redoc/* /openapi.json
    handle @apiGet {
        reverse_proxy localhost:8000
    }

    # All non-GET requests are API calls -> engine
    @apiWrite method POST PUT DELETE PATCH
    handle @apiWrite {
        reverse_proxy localhost:8000
    }

    # Everything else -> React SPA
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}
